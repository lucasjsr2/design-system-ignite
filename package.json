{
    "private": true,
    "packageManager": "bun@1.3.13",
    "engines": {
        "node": ">=22",
        "bun": ">=1.3"
    },
    "scripts": {
        "dev": "turbo run dev --parallel",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "turbo run build --filter=@lucasjsr/docs && changeset publish"
    },
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.27.10",
        "eslint": "^8.25.0",
        "turbo": "^2.3.3"
    }
}
